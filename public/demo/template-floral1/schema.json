{
  "name": "Floral Elegance 1",
  "version": "1.0",
  "pages": [
    {
      "id": "cover",
      "title": "1. Halaman Cover",
      "allow_toggle": true,
      "fields": [
        { "id": "audioUrl", "label": "Link Lagu (BGM) YouTube / MP3", "type": "url" }
      ]
    },
    {
      "id": "hero",
      "title": "2. Halaman 1 (Hero)",
      "allow_toggle": true,
      "photos": [
        {
          "name": "coupleImage",
          "label": "Gunakan Foto Pasangan Sendiri",
          "defaultText": "Foto ilustrasi bawaan template"
        }
      ],
      "fields": [
        { "id": "weddingDate", "label": "Tanggal Acara (Untuk Waktu Mundur)", "type": "date" }
      ]
    },
    {
      "id": "profiles",
      "title": "3. Halaman Profil",
      "allow_toggle": true,
      "photos": [
        {
          "name": "brideImage",
          "label": "Gunakan Foto Sendiri (Wanita)",
          "defaultText": "Foto ilustrasi wanita"
        },
        {
          "name": "groomImage",
          "label": "Gunakan Foto Sendiri (Pria)",
          "defaultText": "Foto ilustrasi pria"
        }
      ],
      "fields": [
        { "id": "separator_1", "label": "Data Mempelai Wanita", "type": "separator" },
        { "id": "brideName", "label": "Nama Wanita", "type": "text" },
        { "id": "brideParents", "label": "Deskripsi (Putri dari...)", "type": "textarea" },
        { "id": "brideInstagram", "label": "Username IG / Sosmed Wanita", "type": "text" },
        { "id": "separator_2", "label": "Data Mempelai Pria", "type": "separator" },
        { "id": "groomName", "label": "Nama Pria", "type": "text" },
        { "id": "groomParents", "label": "Deskripsi (Putra dari...)", "type": "textarea" },
        { "id": "groomInstagram", "label": "Username IG / Sosmed Pria", "type": "text" }
      ]
    },
    {
      "id": "quote",
      "title": "4. Halaman Quotes",
      "allow_toggle": true,
      "fields": [
        { "id": "quoteText", "label": "Quotes / Ayat Suci", "type": "textarea" }
      ]
    },
    {
      "id": "events",
      "title": "5. Halaman Acara",
      "allow_toggle": true,
      "fields": [
        {
          "id": "events",
          "label": "Daftar Acara",
          "type": "repeater",
          "item_title": "Acara",
          "sub_fields": [
            { "id": "title", "label": "Nama Acara (Akad/Resepsi/dll)", "type": "text" },
            { "id": "date", "label": "Tanggal Acara", "type": "date" },
            { "id": "startTime", "label": "Waktu Mulai", "type": "time" },
            { "id": "endTime", "label": "Waktu Selesai", "type": "time" },
            { "id": "locationName", "label": "Nama Gedung/Tempat", "type": "text" },
            { "id": "address", "label": "Alamat Lengkap", "type": "textarea" },
            { "id": "mapsUrl", "label": "Link Google Maps", "type": "url" }
          ]
        }
      ]
    },
    {
      "id": "loveStory",
      "title": "6. Halaman Love Story",
      "allow_toggle": true,
      "fields": [
        {
          "id": "stories",
          "label": "Daftar Cerita",
          "type": "repeater",
          "item_title": "Cerita",
          "sub_fields": [
            { "id": "title", "label": "Judul Cerita", "type": "text" },
            { "id": "date", "label": "Tanggal / Tahun", "type": "text" },
            { "id": "text", "label": "Isi Cerita", "type": "textarea" }
          ]
        }
      ]
    },
    {
      "id": "gift",
      "title": "7. Halaman Gift",
      "allow_toggle": true,
      "fields": [
        { "id": "gift.whatsappNumber", "label": "Nomor WA Klien (Penerima Konfirmasi)", "type": "text", "placeholder": "6281234..." },
        { "id": "separator_3", "label": "Rekening Bank / E-Wallet", "type": "separator" },
        {
          "id": "gift.accounts",
          "label": "Daftar Rekening",
          "type": "repeater",
          "item_title": "Rekening",
          "sub_fields": [
            { "id": "name", "label": "Nama Bank / E-Wallet (BCA/Dana)", "type": "text" },
            { "id": "number", "label": "Nomor Rekening", "type": "text" },
            { "id": "owner", "label": "Atas Nama", "type": "text" }
          ]
        },
        { "id": "separator_4", "label": "Kirim Kado Fisik", "type": "separator" },
        { "id": "gift.physicalAddress", "label": "Alamat Pengiriman", "type": "textarea" },
        { "id": "gift.receiver", "label": "Nama Penerima Paket", "type": "text" }
      ]
    },
    {
      "id": "guestbook",
      "title": "8. Halaman Ucapan & Doa",
      "allow_toggle": true,
      "fields": []
    },
    {
      "id": "closing",
      "title": "9. Halaman Penutup",
      "allow_toggle": true,
      "fields": [
        { "id": "closingText", "label": "Kata Penutup & Salam", "type": "textarea" }
      ]
    }
  ]
}
